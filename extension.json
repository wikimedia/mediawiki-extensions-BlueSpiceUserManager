{
	"name": "BlueSpiceUserManager",
	"license-name": "GPL-3.0-only",
	"version": "5.2.0-alpha",
	"url": "https://en.wiki.bluespice.com/wiki/Reference:BlueSpiceUserManager",
	"author": [
		"Sebastian Ulbricht",
		"Stephan Muggli",
		"Markus Glaser",
		"Leonid Verhovskij"
	],
	"descriptionmsg": "bs-usermanager-desc",
	"type": "bluespice",
	"attributes": {
		"BlueSpiceFoundation": {
			"Extensions": {
				"BlueSpiceUserManager": {
					"className": "\\BlueSpice\\UserManager\\Extension",
					"extPath": "/BlueSpiceUserManager"
				}
			},
			"PermissionRegistry": {
				"usermanager-editpassword": {
					"type": "global",
					"roles": [
						"accountmanager",
						"admin",
						"maintenanceadmin"
					]
				}
			}
		},
		"BlueSpiceDiscovery": {
			"BreadcrumbDataProviderRegistry": {
				"usermanagement": {
					"class": "BlueSpice\\UserManager\\BreadcrumbDataProvider\\SpecialUserManagerProvider",
					"services": [ "SpecialPageFactory" ]
				}
			}
		}
	},
	"requires": {
		"MediaWiki": ">= 1.43.0",
		"extensions": {
			"BlueSpiceFoundation": ">= 5.0",
			"OOJSPlus": ">= 3.0.0"
		}
	},
	"SpecialPages": {
		"UserManager": {
			"class": "BlueSpice\\UserManager\\Special\\UserManager",
			"services": [ "ConfigFactory", "BlueSpice.UserManager.GroupManager" ]
		}
	},
	"ExtensionMessagesFiles": {
		"UserManagerAlias": "SpecialUserManager.alias.php"
	},
	"MessagesDirs": {
		"UserManager": [
			"i18n"
		]
	},
	"AutoloadNamespaces": {
		"BlueSpice\\UserManager\\": "src/"
	},
	"ResourceModules": {
		"ext.bluespice.userManager": {
			"packageFiles": [
				"bluespice.userManager.js",
				"ui/UserManagementPanel.js",
				"ui/GroupDetailsPanel.js",
				"ui/UserPanel.js",
				"ui/GroupsPanel.js",
				"ui/UserDetailsPanel.js",
				"ui/AddUserPanel.js",
				"ui/dialog/EditUserDialog.js",
				"ui/dialog/EditGroupsDialog.js",
				"ui/dialog/AddUserDialog.js",
				"ui/dialog/ResetPasswordDialog.js",
				"ui/dialog/CreateGroupDialog.js",
				"ui/dialog/ShowUserGroupsDialog.js",
				"ui/widget/GroupMembershipWidget.js",
				"ui/dialog/AddGroupMemberDialog.js"
			],
			"styles": {
				"bluespice.userManager.less": {}
			},
			"dependencies": [
				"ext.oOJSPlus.managerPanel",
				"user.options",
				"ext.bluespice",
				"oojs-ui.styles.icons-user",
				"oojs-ui.styles.icons-moderation",
				"oojs-ui.styles.icons-editing-core",
				"ext.oOJSPlus.data"
			],
			"messages": [
				"bs-usermanager-headerusername",
				"bs-usermanager-headerrealname",
				"bs-usermanager-headeremail",
				"bs-usermanager-headerregistration",
				"bs-usermanager-headergroups",
				"bs-usermanager-titleadduser",
				"bs-usermanager-titleeditdetails",
				"bs-usermanager-labelnewpassword",
				"bs-usermanager-labelpasswordcheck",
				"bs-usermanager-headergroups",
				"bs-usermanager-no-self-desysop",
				"bs-usermanager-headerenabled",
				"bs-usermanager-endisable",
				"bs-usermanager-confirmdisableuser",
				"bs-usermanager-confirmenableuser",
				"bs-usermanager-titledisableuser",
				"bs-usermanager-titleenableuser",
				"bs-usermanager-editgroups",
				"bs-usermanager-editpassword",
				"bs-usermanager-label-password-change-strategy",
				"bs-usermanager-label-password-change-strategy-reset",
				"bs-usermanager-label-password-change-strategy-pw",
				"bs-usermanager-save",
				"bs-usermanager-cancel",
				"bs-usermanager-showdisabled",
				"bs-usermanager-disabled",
				"bs-usermanager-warning-password-change-own",
				"bs-usermanager-showenabled",
				"bs-usermanager-mass-enable",
				"bs-usermanager-mass-disable",
				"bs-usermanager-error-generic",
				"bs-usermanager-password-repeat-mismatch-label",
				"bs-usermanager-tab-label-groups",
				"bs-usermanager-tab-label-users",
				"bs-usermanager-member-user-count",
				"bs-usermanager-member-user-info-label",
				"bs-usermanager-member-group-count",
				"bs-usermanager-member-group-info-label",
				"bs-usermanager-showgroups-user-label",
				"bs-usermanager-showgroups-title",
				"bs-usermanager-create-groups-dialog-title",
				"bs-usermanager-action-create",
				"bs-usermanager-create-groups-group-name",
				"bs-usermanager-groups-header-group-name",
				"bs-usermanager-groups-header-members",
				"bs-usermanager-action-edit-group",
				"bs-usermanager-action-delete-group",
				"bs-usermanager-action-create-group",
				"bs-usermanager-group-details-header-user",
				"bs-usermanager-group-details-header-action-remove-member",
				"bs-usermanager-group-details-section-members",
				"bs-usermanager-group-details-section-members-action-add-user",
				"bs-usermanager-group-details-action-delete-group",
				"bs-usermanager-group-details-confirm-delete-group",
				"bs-usermanager-group-details-button-action-label-delete",
				"bs-usermanager-group-details-error-delete-group",
				"bs-usermanager-groups-confirm-remove-member",
				"bs-usermanager-groups-error-remove-member",
				"bs-usermanager-action-label-remove",
				"bs-usermanager-groups-action-add-member-title",
				"bs-usermanager-action-label-add",
				"bs-usermanager-groups-member-field-user"
			]
		}
	},
	"ResourceFileModulePaths": {
		"localBasePath": "resources",
		"remoteExtPath": "BlueSpiceUserManager/resources"
	},
	"GroupPermissions": {
		"sysop": {
			"usermanager-editpassword": true
		}
	},
	"AvailableRights": [
		"usermanager-editpassword"
	],
	"HookHandlers": {
		"common-user-interface": {
			"class": "\\BlueSpice\\UserManager\\HookHandler\\CommonUserInterface"
		},
		"registerDynamicConfig": {
			"class": "\\BlueSpice\\UserManager\\HookHandler\\RegisterDynamicConfig"
		}
	},
	"ServiceWiringFiles": [
		"includes/ServiceWiring.php"
	],
	"RestRoutes": [
		{
			"method": "POST",
			"path": "/bs-usermanager/v1/user/create/{username}",
			"class": "\\BlueSpice\\UserManager\\Rest\\AddUserHandler",
			"services": [ "BlueSpice.UserManager.Manager", "UserFactory" ]
		},
		{
			"method": "POST",
			"path": "/bs-usermanager/v1/user/edit/{username}",
			"class": "\\BlueSpice\\UserManager\\Rest\\UpdateUserHandler",
			"services": [ "BlueSpice.UserManager.Manager", "UserFactory" ]
		},
		{
			"method": "POST",
			"path": "/bs-usermanager/v1/block/create",
			"class": "\\BlueSpice\\UserManager\\Rest\\BlockUsersHandler",
			"services": [ "BlueSpice.UserManager.Manager", "UserFactory" ]
		},
		{
			"method": "POST",
			"path": "/bs-usermanager/v1/block/delete",
			"class": "\\BlueSpice\\UserManager\\Rest\\UnblockUsersHandler",
			"services": [ "BlueSpice.UserManager.Manager", "UserFactory" ]
		},
		{
			"method": "POST",
			"path": "/bs-usermanager/v1/groups/set",
			"class": "\\BlueSpice\\UserManager\\Rest\\SetGroupsHandler",
			"services": [ "BlueSpice.UserManager.Manager", "UserFactory" ]
		},
		{
			"method": "POST",
			"path": "/bs-usermanager/v1/password/{username}",
			"class": "\\BlueSpice\\UserManager\\Rest\\ChangePasswordHandler",
			"services": [ "BlueSpice.UserManager.Manager", "UserFactory" ]
		},
		{
			"method": "POST",
			"path": "/bs-usermanager/v1/groups/create/{name}",
			"class": "BlueSpice\\UserManager\\Rest\\AddGroup",
			"services": [ "BlueSpice.UserManager.GroupManager" ]
		},
		{
			"method": "POST",
			"path": "/bs-usermanager/v1/groups/edit/{name}/{newName}",
			"class": "BlueSpice\\UserManager\\Rest\\EditGroup",
			"services": [ "BlueSpice.UserManager.GroupManager" ]
		},
		{
			"method": "POST",
			"path": "/bs-usermanager/v1/groups/delete/{name}",
			"class": "BlueSpice\\UserManager\\Rest\\DeleteGroup",
			"services": [ "BlueSpice.UserManager.GroupManager" ]
		},
		{
			"method": "GET",
			"path": "/bs-usermanager/v1/groups/members/{name}",
			"class": "BlueSpice\\UserManager\\Rest\\GetGroupMembers",
			"services": [ "BlueSpice.UserManager.GroupManager" ]
		},
		{
			"method": "POST",
			"path": "/bs-usermanager/v1/groups/assign/{group}",
			"class": "BlueSpice\\UserManager\\Rest\\AddUserToGroup",
			"services": [ "BlueSpice.UserManager.Manager", "UserFactory" ]
		},
		{
			"method": "POST",
			"path": "/bs-usermanager/v1/groups/unassign/{group}",
			"class": "BlueSpice\\UserManager\\Rest\\RemoveUserFromGroup",
			"services": [ "BlueSpice.UserManager.Manager", "UserFactory" ]
		}
	],
	"Hooks": {
		"MWStakeCommonUIRegisterSkinSlotComponents": "common-user-interface",
		"BeforePageDisplay": "\\BlueSpice\\UserManager\\Hook\\BeforePageDisplay\\AddModules::callback",
		"MWStakeDynamicConfigRegisterConfigs": "registerDynamicConfig"
	},
	"config_prefix": "bsg",
	"config": {
		"UserManagerForceResetLink": {
			"value": false
		}
	},
	"load_composer_autoloader": true,
	"manifest_version": 2
}
